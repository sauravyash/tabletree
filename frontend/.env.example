# Copy to frontend/.env for local dev. These same keys are the build environment
# variables to set in Netlify (Site config -> Environment variables).
#
# The URL + anon key are public (Vite inlines them into the client bundle by design);
# netlify.toml's SECRETS_SCAN_OMIT_PATHS keeps the secrets scanner from flagging them.

# Hosted Supabase project "tabletree" (ref ifyvsrmdnmqlqifcqpnx)
VITE_SUPABASE_URL=https://ifyvsrmdnmqlqifcqpnx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_FXVsKctcVMYQYzTczzxcug_8brkCsGi

# Demo booking auto sign-in (seeded dev user + booking). Not for production.
VITE_DEMO_EMAIL=demo@tabletree.test
VITE_DEMO_PASSWORD=demo-password
VITE_DEMO_BOOKING_ID=00000000-0000-0000-0000-000000000001
